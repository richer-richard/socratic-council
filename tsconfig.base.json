{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@socratic-council/shared": ["packages/shared/src/index.ts"],
      "@socratic-council/shared/*": ["packages/shared/src/*"],
      "@socratic-council/sdk": ["packages/sdk/src/index.ts"],
      "@socratic-council/sdk/*": ["packages/sdk/src/*"],
      "@socratic-council/core": ["packages/core/src/index.ts"],
      "@socratic-council/core/*": ["packages/core/src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "exclude": ["node_modules", "dist", "build"]
}
